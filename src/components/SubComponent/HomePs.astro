---
import GithubIcon from "../SubComponent/Icons/GithubIcon.astro"
import InstagramIcons from "../SubComponent/Icons/InstagramIcons.astro"
import LinkedinIcon from "../SubComponent/Icons/LinkedinIcon.astro"
---

<article class="flex gap-4 h-[70vh] ">
    <section class="flex-[25%] flex flex-col items-end justify-center">
        <div class="flex flex-col justy p-4 gap-8">
            <GithubIcon />
            <InstagramIcons />
            <LinkedinIcon />
        </div>
    </section>
    <section class="flex flex-[75%] w-[75%] flex-col justify-center gap-2 ">
        <div class="">
            <p class="text-[#C7FFED] text-base">Hello, my name is</p>
        </div>
        <div class="mt-7">
            <h1 class="font-bold text-7xl">Keiver Luna</h1>
        </div>
        <div>
            <h1 class="font-bold text-6xl text-zinc-400">Imagine First  Second Create.</h1>
        </div>
        <div class="mt-10 text-zinc-500 text-base">
            <p> I am a front-end programmer and part of UX and UI, <br>
                I create the structure of the website and its style.</p>
        </div>
        <div class="mt-6 w-32 h-10 border border-white flex justify-center items-center text-center transition duration-300 hover:bg-[#9AEBA3] hover:text-black cursor-pointer hover:shadow-md hover:shadow-white">
            <a href="#">Let’s Go!</a>
        </div>
    </section>
</article>